# Django / backend
DJANGO_DEBUG=false
DJANGO_SECRET_KEY=replace-with-a-real-secret
DJANGO_ALLOWED_HOSTS=app.example.com,api.example.com
DJANGO_CORS_ALLOWED_ORIGINS=https://app.example.com
DJANGO_CSRF_TRUSTED_ORIGINS=https://app.example.com
DJANGO_TEST_SYSTEM_ENABLED=false
DJANGO_TIME_ZONE=America/New_York
DATABASE_URL=postgres://prod_user:replace-with-a-real-password@db:5432/dachong_wms
DB_SSL_REQUIRED=false

# Postgres
POSTGRES_DB=dachong_wms
POSTGRES_USER=prod_user
POSTGRES_PASSWORD=replace-with-a-real-password

# Gunicorn
GUNICORN_WORKERS=3
GUNICORN_TIMEOUT=120

# Frontend build
VITE_ENABLE_TEST_SYSTEM=false
