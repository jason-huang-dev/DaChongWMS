# Docker production example.
# Copy to `.env.prod` for `make prod`.
# For Vercel + Supabase, use `backend/.env.vercel.example` and `frontend/.env.vercel.example` instead.

# Django / backend
DJANGO_SETTINGS_MODULE=config.settings.prod
DJANGO_DEBUG=false
DJANGO_SECRET_KEY=replace-with-a-real-secret
DJANGO_ALLOWED_HOSTS=dachongwms-backend.vercel.app
DJANGO_CORS_ALLOWED_ORIGINS=https://dachongwms-frontend.vercel.app
DJANGO_CSRF_TRUSTED_ORIGINS=https://dachongwms-frontend.vercel.app,https://dachongwms-backend.vercel.app
DJANGO_CORS_ALLOW_CREDENTIALS=true
DJANGO_TEST_SYSTEM_ENABLED=false
DJANGO_TIME_ZONE=America/New_York
DATABASE_URL=postgresql://postgres.zimhwusclepfjwunwdcb:[YOUR-PASSWORD]@aws-1-us-east-2.pooler.supabase.com:5432/postgres
DJANGO_DB_CONN_MAX_AGE=600
DB_SSL_REQUIRED=true
# Uncomment only if you need Django session cookies across separate frontend/backend origins.
# DJANGO_SESSION_COOKIE_SAMESITE=None
# DJANGO_CSRF_COOKIE_SAMESITE=None

# Postgres
# These are only used if you still run the optional Docker `db` service.
# When DATABASE_URL points at Supabase, the backend ignores the local container credentials below.
POSTGRES_DB=dachong
POSTGRES_USER=prod_user
POSTGRES_PASSWORD=replace-with-a-real-password

# Gunicorn
GUNICORN_WORKERS=3
GUNICORN_TIMEOUT=120

# Frontend build
VITE_ENABLE_TEST_SYSTEM=false
