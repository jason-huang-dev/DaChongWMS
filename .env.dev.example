# Local Docker development example.
# Copy to `.env.dev` for `make dev`.
# Frontend-only Vite variables belong in `frontend/.env.local`.

# Django / backend
DJANGO_SETTINGS_MODULE=config.settings.dev
DJANGO_DEBUG=true
DJANGO_SECRET_KEY=insecure-dev-secret-key-change-me
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0,backend,frontend,host.docker.internal
DJANGO_CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
DJANGO_CSRF_TRUSTED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
DJANGO_CORS_ALLOW_CREDENTIALS=true
DJANGO_TEST_SYSTEM_ENABLED=true
DJANGO_TIME_ZONE=America/New_York
DATABASE_URL=postgresql://myuser:mypassword@db:5432/mydatabase
DJANGO_DB_CONN_MAX_AGE=0
DB_SSL_REQUIRED=false
# Uncomment only if you need Django session cookies across different dev origins.
# DJANGO_SESSION_COOKIE_SAMESITE=None
# DJANGO_CSRF_COOKIE_SAMESITE=None

# Postgres
POSTGRES_DB=mydatabase
POSTGRES_USER=myuser
POSTGRES_PASSWORD=mypassword

# Optional bootstrap user
SUPERUSER_USERNAME=admin
SUPERUSER_EMAIL=admin@example.com
SUPERUSER_PASSWORD=change-me
