# Local backend environment for running Django directly on your machine.
# Copy to `backend/.env.local` before using `make run_backend_local`,
# `make makemigrations_local`, or `make migrate_local`.

DJANGO_SETTINGS_MODULE=config.settings.dev
DJANGO_DEBUG=true
DJANGO_SECRET_KEY=insecure-dev-secret-key-change-me
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
DJANGO_CSRF_TRUSTED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
DJANGO_CORS_ALLOW_CREDENTIALS=true
DJANGO_TEST_SYSTEM_ENABLED=true
DJANGO_TIME_ZONE=America/New_York
DATABASE_URL=postgresql://myuser:mypassword@127.0.0.1:5432/mydatabase
DJANGO_DB_CONN_MAX_AGE=0
DB_SSL_REQUIRED=false
# Uncomment only if you need Django session cookies across different local origins.
# DJANGO_SESSION_COOKIE_SAMESITE=None
# DJANGO_CSRF_COOKIE_SAMESITE=None
