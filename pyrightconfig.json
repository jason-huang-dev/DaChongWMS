{
  "include": [
    "backend/apps",
    "backend/config"
  ],
  "stubPath": "backend/typings",
  "exclude": [
    "**/__pycache__",
    "backend/apps/legacy"
  ],
  "typeCheckingMode": "strict",
  "reportMissingTypeStubs": false,
  "executionEnvironments": [
    {
      "root": "backend",
      "extraPaths": [
        "backend"
      ]
    }
  ]
}
